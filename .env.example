# =============================================================================
# Wardrive — Environment variables example
# =============================================================================
# Copy to .env and adjust. All services (wardrive, celery, wardrive_proxy)
# use env_file: .env in docker-compose / podman-compose.
# =============================================================================

# ----- Django core (required) -----
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
# Production example: ALLOWED_HOSTS=wardrive.example.com,api.wardrive.example.com

# ----- Database (PostgreSQL) -----
DB_ENGINE=django.db.backends.postgresql
DB_NAME=wardrive
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=wardrive_db
DB_PORT=5432

# ----- Run mode (start.sh) -----
# local = runserver + wait for DB; container = gunicorn (no wait)
ENVIRONMENT=container

# ----- Static & Media URLs (optional; defaults built from FORCE_SCRIPT_NAME) -----
FORCE_SCRIPT_NAME=
# STATIC_URL=/static/
# MEDIA_URL=/media/

# ----- Storage: S3 / MinIO (optional). Two buckets: wardrive + CTFd -----
# Set USE_S3_STORAGE=true to store media in MinIO. At startup both buckets are created if missing.
# - AWS_STORAGE_BUCKET_NAME: bucket for wardrive (underscores are auto-converted to hyphens).
# - CTFD_S3_BUCKET: bucket for CTFd. Use only lowercase letters, numbers, hyphens (no underscores).
# If USE_S3_STORAGE=false but CTFd uses S3, create CTFD_S3_BUCKET manually in MinIO.
# In nginx.conf, comment the filesystem /media/ block and uncomment the proxy_pass block.
USE_S3_STORAGE=false
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=media
CTFD_S3_BUCKET=ctfd
AWS_S3_REGION_NAME=us-east-1
AWS_S3_FILE_OVERWRITE=false
AWS_DEFAULT_ACL=public-read
AWS_S3_CACHE_CONTROL=max-age=86400
AWS_S3_QUERYSTRING_AUTH=false

# ----- MinIO (used by docker-compose / podman-compose minio service) -----
# Same credentials used by wardrive and CTFd (each with its own bucket).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ----- Redis -----
# Optional: full URL (e.g. Railway Redis: redis://default:PASSWORD@host:port/0).
# If set, Celery broker/result backend are derived from it (db 0 and 1); no password in REDIS_HOST.
# REDIS_URL=
REDIS_USERNAME=default
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# Only used when REDIS_URL is not set: redis://USERNAME:REDIS_PASSWORD@REDIS_HOST:PORT/DB
# REDIS_PASSWORD=

# ----- Celery -----
# If REDIS_URL is set, these default to REDIS_URL with db 0 and 1. Otherwise set explicitly.
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Must match deployed Celery workers: compose ships proc_0 + proc_1 → use 2 unless you add services.
CELERY_SHARDS=2
# Queue name for workers (proc_0, proc_1, ...)
# QUEUE=proc_0

# ----- Security -----
# Comma-separated origins for CSRF (e.g. https://wardrive.example.com)
# CSRF_TRUSTED_ORIGINS=https://wardrive.example.com,https://api.wardrive.example.com

# ----- CTFd (DEPRECATED — reemplazado por wardrive-frontend) -----
# Las siguientes variables ya no son necesarias. Se mantienen como referencia.
# Para limpiar los recursos de CTFd ejecuta: ./cleanup_ctfd.sh
# REVERSE_PROXY=true
# APPLICATION_ROOT=/ctf
# PREFERRED_URL_SCHEME=https
# DATABASE_URL=postgresql://postgres:postgres@wardrive_db:5432/ctfd
# CTFD_S3_BUCKET=ctfd

# ----- Analytics (Latitude) -----
# Genera LATITUDE_MASTER_KEY con: openssl rand -hex 64
LATITUDE_MASTER_KEY=genera_con_openssl_rand_hex_64

# Rango de fechas por defecto para las queries de analytics (ISO 8601 con offset de zona horaria)
# El frontend puede sobreescribir estos valores vía query params: ?first_seen_start=...&first_seen_end=...
# Estos valores son solo documentación de referencia; los defaults reales viven en el SQL (param(...))
ANALYTICS_DEFAULT_START_DATE=2025-01-01T00:00:00-06:00
ANALYTICS_DEFAULT_END_DATE=2026-05-30T00:00:00-06:00
ANALYTICS_MIN_DATE=2025-01-01T00:00:00-06:00
ANALYTICS_MAX_DATE=2026-05-30T23:59:59.999-06:00

# ----- Frontend Analytics (Vite VITE_* — inyectadas en el bundle del cliente) -----
# Fechas iniciales que el frontend React usa en los DatePickers de la página Analytics.
# Deben coincidir con ANALYTICS_DEFAULT_START_DATE / ANALYTICS_DEFAULT_END_DATE.
VITE_ANALYTICS_DEFAULT_START_DATE=2025-01-01T00:00:00-06:00
VITE_ANALYTICS_DEFAULT_END_DATE=2026-05-30T00:00:00-06:00
VITE_ANALYTICS_MIN_DATE=2025-01-01T00:00:00-06:00
VITE_ANALYTICS_MAX_DATE=2026-05-30T23:59:59.999-06:00
VITE_ANALYTICS_API_URL=http://YOUR_HOST_IP:3001/api

ANALYTICS_BIND_IP=0.0.0.0

# ----- CORS -----
CORS_ORIGIN_ALLOW_ALL=false

# ----- Email / SMTP -----
# Backend de correo (usar console en desarrollo, smtp en producción)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@example.com

# ----- Email branding (plantillas HTML de correo) -----
# Nombre que aparece en los correos como remitente/firma
EMAIL_SITE_NAME=Wardrive
# Correo de soporte mostrado en el footer de los correos
EMAIL_SUPPORT_EMAIL=soporte@example.com
# URL absoluta del logo en el header del correo (puede ser S3/MinIO o estático)
EMAIL_LOGO_URL=https://example.com/static/img/logo.png

# Correo de bienvenida — párrafo introductorio (usa \n para saltos de línea)
EMAIL_WELCOME_INTRO=Bienvenido a la plataforma del CTF de wardriving.\nTu cuenta está lista: aquí podrás participar subiendo capturas y consultando los resultados del evento.
# Correo de bienvenida — capacidades de la plataforma, una por línea (usa \n como separador)
# Cada entrada genera un <li> en el HTML y una viñeta "- " en el texto plano.
EMAIL_WELCOME_FEATURES=Subir archivos de captura (Upload)\nExplorar mapas de wardriving WiFi y LTE\nRevisar analytics del evento\nDescargar exportaciones KML

# ----- Reset de contraseña (API REST / SPA) -----
# URL base del frontend incluyendo el basename de React Router (sin slash final)
# Ejemplo producción: https://wardrive.example.com/ctf
# Ejemplo desarrollo: http://localhost:5173/ctf
PASSWORD_RESET_FRONTEND_BASE_URL=http://localhost:5173/ctf
# Ruta relativa de la página de confirmación en el SPA (default: reset-password)
# El enlace final quedará: PASSWORD_RESET_FRONTEND_BASE_URL/PASSWORD_RESET_PATH?uid=...&token=...
# PASSWORD_RESET_PATH=reset-password

# URL de login/app usada en el correo de bienvenida
FRONTEND_LOGIN_URL=http://localhost:5173/ctf/login

# ----- Swagger / API docs -----
SWAGGER_EMAIL=admin@example.com
SWAGGER_AUTHOR=Wardrive Team
SWAGGER_CONTACT_URL=https://example.com
SWAGGER_LICENSE=MIT
SWAGGER_USE_SESSION_AUTH=false
